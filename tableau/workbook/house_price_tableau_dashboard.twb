      <aliases enabled="yes" />
      <column caption="Price per Area" datatype="real" name="[Calculation_0331240441368579]" role="measure" type="quantitative">
        <calculation class="tableau" formula="[price] / [area]" />
      </column>
      <column caption="Property Age Band" datatype="string" name="[Calculation_0331240441815044]" role="dimension" type="nominal">
        <calculation class="tableau" formula="IF [age] &lt;= 5 THEN '0-5 years' ELSEIF [age] &lt;= 15 THEN '6-15 years' ELSEIF [age] &lt;= 25 THEN '16-25 years' ELSE '26+ years' END" />
      </column>
      <column caption="Distance Band" datatype="string" name="[Calculation_0331240442011653]" role="dimension" type="nominal">
        <calculation class="tableau" formula="IF [distance] &lt;= 5 THEN '0-5' ELSEIF [distance] &lt;= 15 THEN '6-15' ELSE '16+' END" />
      </column>
      <column caption="Amenity Score" datatype="integer" name="[Calculation_0331240442130438]" role="measure" type="quantitative">
        <calculation class="tableau" formula="[garage] + [parking] + [garden] + [security] + [school_nearby] + [hospital_nearby] + [shopping_mall_nearby] + [public_transport]" />
      </column>
      <column caption="Price Band" datatype="string" name="[Calculation_0331240442245127]" role="dimension" type="nominal">
        <calculation class="tableau" formula="IF [price] &lt; 500000 THEN 'Below 500k price units' ELSEIF [price] &lt; 1000000 THEN '500k-1m price units' ELSEIF [price] &lt; 1500000 THEN '1m-1.5m price units' ELSE '1.5m+ price units' END" />
      </column>
      <column caption="Selected Metric" datatype="real" name="[Calculation_0331240443785228]" role="measure" type="quantitative">
        <calculation class="tableau" formula="CASE [Parameters].[Parameter 1] WHEN 'Average Price' THEN AVG([price]) WHEN 'Median Price' THEN MEDIAN([price]) WHEN 'Price per Area' THEN AVG([Calculation_0331240441368579]) END" />
      </column>
