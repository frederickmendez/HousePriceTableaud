    <worksheet name="Actual vs Predicted Price">
      <table>
        <view>
          <datasources>
            <datasource caption="Model Predictions" name="federated.model_predictions.112c32a22c9d" />
          </datasources>
          <datasource-dependencies datasource="federated.model_predictions.112c32a22c9d">
            <column caption="Absolute Prediction Error" datatype="real" name="[Calculation_model_absolute_error]" role="measure" type="quantitative">
              <calculation class="tableau" formula="ABS([Calculation_model_residual])" />
            </column>
            <column caption="Prediction Error Percentage" datatype="real" name="[Calculation_model_error_percentage]" role="measure" type="quantitative">
              <calculation class="tableau" formula="[Calculation_model_absolute_error] / [actual_price]" />
            </column>
            <column caption="Prediction Quality Band" datatype="string" name="[Calculation_model_quality_band]" role="dimension" type="nominal">
              <calculation class="tableau" formula="IF [Calculation_model_error_percentage] &lt;= 0.02 THEN 'Low error (0-2%)' ELSEIF [Calculation_model_error_percentage] &lt;= 0.05 THEN 'Moderate error (2-5%)' ELSE 'High review priority (&gt;5%)' END" />
            </column>
            <column caption="Actual-Predicted Residual" datatype="real" name="[Calculation_model_residual]" role="measure" type="quantitative">
              <calculation class="tableau" formula="[actual_price] - [predicted_price]" />
            </column>
            <column caption="Actual Price" datatype="real" name="[actual_price]" role="measure" type="quantitative" />
            <column-instance column="[Calculation_model_quality_band]" derivation="None" name="[none:Calculation_model_quality_band:nk]" pivot="key" type="nominal" />
            <column-instance column="[record_id]" derivation="None" name="[none:record_id:nk]" pivot="key" type="nominal" />
            <column caption="Predicted Price" datatype="real" name="[predicted_price]" role="measure" type="quantitative" />
            <column caption="Record Id" datatype="string" name="[record_id]" role="dimension" type="nominal" />
            <column-instance column="[actual_price]" derivation="Sum" name="[sum:actual_price:qk]" pivot="key" type="quantitative" />
            <column-instance column="[predicted_price]" derivation="Sum" name="[sum:predicted_price:qk]" pivot="key" type="quantitative" />
            <column caption="Location" datatype="string" name="[location]" role="dimension" type="nominal" />
            <column-instance column="[location]" derivation="None" name="[none:location:nk]" pivot="key" type="nominal" />
            <column caption="Income Level" datatype="string" name="[income_level]" role="dimension" type="nominal" />
            <column-instance column="[income_level]" derivation="None" name="[none:income_level:nk]" pivot="key" type="nominal" />
            <column caption="Review Priority" datatype="string" name="[Calculation_model_review_priority]" role="dimension" type="nominal" />
            <column-instance column="[Calculation_model_review_priority]" derivation="None" name="[none:Calculation_model_review_priority:nk]" pivot="key" type="nominal" />
          </datasource-dependencies>
          <filter class="categorical" column="[federated.model_predictions.112c32a22c9d].[none:location:nk]">
            <groupfilter function="level-members" level="[none:location:nk]" />
          </filter>
          <filter class="categorical" column="[federated.model_predictions.112c32a22c9d].[none:income_level:nk]">
            <groupfilter function="level-members" level="[none:income_level:nk]" />
          </filter>
          <filter class="categorical" column="[federated.model_predictions.112c32a22c9d].[none:Calculation_model_quality_band:nk]">
            <groupfilter function="level-members" level="[none:Calculation_model_quality_band:nk]" />
          </filter>
          <filter class="categorical" column="[federated.model_predictions.112c32a22c9d].[none:Calculation_model_review_priority:nk]">
            <groupfilter function="level-members" level="[none:Calculation_model_review_priority:nk]" />
          </filter>
          <slices>
