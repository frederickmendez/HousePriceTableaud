            <column>[federated.model_predictions.112c32a22c9d].[none:income_level:nk]</column>
            <column>[federated.model_predictions.112c32a22c9d].[none:Calculation_model_quality_band:nk]</column>
            <column>[federated.model_predictions.112c32a22c9d].[none:Calculation_model_review_priority:nk]</column>
          </slices>
          <aggregation value="true" />
        </view>
