    <worksheet name="Prediction Error by Review Priority">
      <table>
        <view>
          <datasources>
            <datasource caption="Model Predictions" name="federated.model_predictions.112c32a22c9d" />
          </datasources>
          <datasource-dependencies datasource="federated.model_predictions.112c32a22c9d">
            <column caption="Absolute Prediction Error" datatype="real" name="[Calculation_model_absolute_error]" role="measure" type="quantitative">
              <calculation class="tableau" formula="ABS([Calculation_model_residual])" />
            </column>
            <column caption="Prediction Error Percentage" datatype="real" name="[Calculation_model_error_percentage]" role="measure" type="quantitative">
              <calculation class="tableau" formula="[Calculation_model_absolute_error] / [actual_price]" />
            </column>
            <column caption="Prediction Quality Band" datatype="string" name="[Calculation_model_quality_band]" role="dimension" type="nominal">
              <calculation class="tableau" formula="IF [Calculation_model_error_percentage] &lt;= 0.02 THEN 'Low error (0-2%)' ELSEIF [Calculation_model_error_percentage] &lt;= 0.05 THEN 'Moderate error (2-5%)' ELSE 'High review priority (&gt;5%)' END" />
            </column>
            <column caption="Actual-Predicted Residual" datatype="real" name="[Calculation_model_residual]" role="measure" type="quantitative">
              <calculation class="tableau" formula="[actual_price] - [predicted_price]" />
            </column>
            <column caption="Review Priority" datatype="string" name="[Calculation_model_review_priority]" role="dimension" type="nominal">
              <calculation class="tableau" formula="IF [Calculation_model_error_percentage] &gt; 0.05 OR [Calculation_model_absolute_error] &gt; 19940.838 THEN 'High' ELSEIF [Calculation_model_error_percentage] &gt; 0.02 THEN 'Medium' ELSE 'Low' END" />
            </column>
            <column caption="Absolute Error" datatype="real" name="[absolute_error]" role="measure" type="quantitative" />
            <column caption="Actual Price" datatype="real" name="[actual_price]" role="measure" type="quantitative" />
            <column-instance column="[Calculation_model_quality_band]" derivation="None" name="[none:Calculation_model_quality_band:nk]" pivot="key" type="nominal" />
